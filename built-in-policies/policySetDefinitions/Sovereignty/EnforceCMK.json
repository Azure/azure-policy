{
  "properties": {
    "displayName": "[Preview]: Enforce Encryption-at-Rest with Customer Managed Keys (CMK) with Azure Key Vault Premium Keys across Azure Services",
    "policyType": "BuiltIn",
    "description": "Help restrict and audit Azure Services to use CMK with Azure Key Vault Premium keys",
    "metadata": {
      "version": "1.0.0-preview",
      "category": "Sovereignty",
      "preview": true,
      "SovereigntyLevel": "Level 2 - Encryption at-rest/in-transit"
    },
    "version": "1.0.0-preview",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "This parameter lets you choose the effect of the policy. If you choose Audit, the policy will only audit resources for compliance. If you choose Deny (default), the policy will deny the creation of non-compliant resources. If you choose Disabled, the policy will not enforce compliance (useful, for example, as a second assignment to ignore a subset of non-compliant resources in a single resource group)."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "86efb160-8de7-451d-bc08-5d475b0aadae_supportedSKUs": {
        "type": "Array",
        "metadata": {
          "displayName": "Supported SKUs for Azure Data Box Jobs",
          "description": "The list of SKUs that support customer-managed key encryption key for Azure Data Box Jobs"
        },
        "allowedValues": [
          "DataBox",
          "DataBoxHeavy"
        ],
        "defaultValue": [
          "DataBox",
          "DataBoxHeavy"
        ]
      },
      "2e94d99a-8a36-4563-bc77-810d8893b671_enableDoubleEncryption": {
        "type": "Boolean",
        "metadata": {
          "displayName": "Double encryption should be enabled on Azure Recovery Services vaults for Backup",
          "description": "Check if double encryption is enabled on Azure Recovery Services vaults for Backup.  For more details refer to https://aka.ms/AB-InfraEncryption."
        },
        "allowedValues": [
          true,
          false
        ],
        "defaultValue": false
      },
      "d6588149-9f06-462c-a076-56aece45b5ba_checkInfrastructureEncryption": {
        "type": "Boolean",
        "metadata": {
          "displayName": "Check if Infrastructure Encryption is enabled on AzureBackup vaults.",
          "description": "Check if Infrastructure Encryption is enabled on Azure Backup Vaults. For more details refer to https://aka.ms/az-backup-vault-infra-encryption-at-rest-with-cmk."
        },
        "allowedValues": [
          true,
          false
        ],
        "defaultValue": false
      },
      "67121cc7-ff39-4ab8-b7e3-95b84dab487d_excludedKinds": {
        "type": "Array",
        "metadata": {
          "displayName": "Excluded Kinds in Azure AI Services",
          "description": "The list of excluded API kinds for customer-managed key, default is the list of API kinds that don't have data stored in Cognitive Services"
        },
        "defaultValue": [
          "CognitiveServices",
          "ContentSafety",
          "ImmersiveReader",
          "HealthInsights",
          "LUIS.Authoring",
          "LUIS",
          "QnAMaker",
          "QnAMaker.V2",
          "AIServices",
          "MetricsAdvisor",
          "SpeechTranslation",
          "Internal.AllInOne",
          "ConversationalLanguageUnderstanding",
          "knowledge",
          "TranscriptionIntelligence",
          "HealthDecisionSupport"
        ]
      }
    },
