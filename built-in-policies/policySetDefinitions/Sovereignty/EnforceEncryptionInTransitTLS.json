    "parameters": {
      "effect_deny": {
        "type": "String",
        "metadata": {
          "displayName": "Effect-Deny",
          "description": "This effect applies to policies that support Deny or Audit effect."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "effect_modify": {
        "type": "String",
        "metadata": {
          "displayName": "Effect-Modify",
          "description": "This effect applies to policies that support Modify effect."
        },
        "allowedValues": [
          "Modify",
          "Disabled"
        ],
        "defaultValue": "Modify"
      },
      "effect_deployIfNotExists": {
        "type": "String",
        "defaultValue": "DeployIfNotExists",
        "allowedValues": [
          "DeployIfNotExists",
          "Disabled"
        ],
