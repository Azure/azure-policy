          "displayName": "Effect-DeployIfNotExists",
          "description": "This effect applies to policies that support DeployIfNotExists effect."
        }
      },
      "effect_auditIfNotExists": {
        "type": "String",
        "defaultValue": "AuditIfNotExists",
        "allowedValues": [
          "AuditIfNotExists",
          "Disabled"
        ],
        "metadata": {
          "displayName": "Effect-AuditIfNotExists",
          "description": "This effect applies to policies that support AuditIfNotExists effect."
        }
      },
      "includeArcMachines": {
        "type": "String",
        "metadata": {
          "displayName": "Include Arc connected servers",
          "description": "By selecting this option, you agree to be charged monthly per Arc connected machine.",
          "portalReview": "true"
        },
        "allowedValues": [
          "true",
          "false"
        ],
        "defaultValue": "false"
      },
      "fe83a0eb-a853-422d-aac2-1bffd182c5d0_minimumTlsVersion": {
        "type": "String",
        "metadata": {
          "displayName": "Minimum TLS Version",
          "description": "Minimum version of TLS required to access data in the storage account"
        },
        "allowedValues": [
          "TLS1_0",
          "TLS1_1",
          "TLS1_2"
        ],
        "defaultValue": "TLS1_2"
      },
      "828ba269-bf7f-4082-83dd-633417bc391d_minimumServerTLSVersion": {
        "type": "String",
        "metadata": {
          "displayName": "Minimum Machine TLS version",
          "description": "The minimum machine TLS protocol version that should be enabled. Windows machines with lower TLS versions will be set to the desired version."
        },
        "allowedValues": [
          "1.1",
          "1.2"
        ],
        "defaultValue": "1.2"
      },
      "828ba269-bf7f-4082-83dd-633417bc391d_minimumClientTLSVersion": {
        "type": "String",
        "metadata": {
          "displayName": "Minimum Client TLS version",
          "description": "The minimum client TLS protocol version that should be enabled. Windows machines with lower client TLS versions will be set to desired version."
