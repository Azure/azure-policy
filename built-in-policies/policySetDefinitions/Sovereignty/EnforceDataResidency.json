  "properties": {
    "displayName": "[Preview]: Enforce Data Residency across Azure Services",
    "policyType": "BuiltIn",
    "description": "Help restrict and audit the Azure Regions that Azure Services can be deployed into. Helping to enforce Level 1 - Data Residency Sovereignty Controls detailed here: https://aka.ms/sovereign/controls",
    "metadata": {
      "version": "1.0.0-preview",
      "category": "Sovereignty",
      "preview": true,
      "SovereigntyLevel": "Level 1 - Data Residency"
    },
