        "policyDefinitionReferenceId": "CosmosDBShouldRestrictPublicAccessWithAllowedIPRules",
        "definitionVersion": "1.*.*",
        "parameters": {
          "effect": {
            "value": "[parameters('publicWithIPEffect')]"
          },
          "allowedIPRules": {
            "value": "[parameters('allowedIPRules')]"
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/ea79b84d-f538-475d-a6ef-7951747a3455",
        "policyDefinitionReferenceId": "CosmosDBShouldRestrictExternalPrivateEndPoints",
        "definitionVersion": "1.*.*",
        "parameters": {
          "effect": {
            "value": "[parameters('privateEndPointEffect')]"
          },
          "excludedSubscriptionIDs": {
            "value": "[parameters('excludedSubscriptionIDs')]"
          }
        }
      }
    ],
    "versions": [
      "1.0.0"
