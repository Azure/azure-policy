{
  "properties": {
    "displayName": "Control the use of Azure SQL in Mission Platforms",
    "policyType": "BuiltIn",
    "description": "This policy set applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. It deploys coordinated Azure SQL controls to enforce private networking, outbound restrictions, and customer-managed encryption for mission workloads (see https://learn.microsoft.com/azure/azure-sql/database/security-overview).",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "sqlDatabaseRestrictNetAccessEffect": {
        "type": "String",
        "metadata": {
          "displayName": "SQL Database restrict network access",
          "description": "Enable or Disable the restriction of network access"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "sqlServerEnableOutboundNetworkRestrictions": {
        "type": "String",
        "metadata": {
          "displayName": "SQL Server restrict outbound network",
          "description": "Enable or Disable the restriction of outbound network"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "encryptSqlServerWithCmkEffect": {
        "type": "String",
        "metadata": {
          "displayName": "SQL server encrypt with Customer Managed Key (CMK)",
          "description": "Enable or Disable encryption with Customer Managed Key (CMK)"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "restrictExternalPeSqlServerEffect": {
        "type": "String",
        "metadata": {
          "displayName": "SQL Server restrict external Private Endpoint",
          "description": "Deny external Private Endpoints to SQL Servers"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "restrictExternalPeSqlServer_excludedSubIDs": {
        "type": "Array",
        "metadata": {
          "displayName": "SQL Server restrict external Private Endpoint on excluded subscriptions",
          "description": "Deny external Private Endpoints to SQL Servers  on excluded subscriptions"
        },
        "defaultValue": []
      }
    },
