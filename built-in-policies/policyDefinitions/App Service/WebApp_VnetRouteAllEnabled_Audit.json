{
  "properties": {
    "displayName": "App Service apps should enable outbound application traffic routing to Azure Virtual Network",
    "policyType": "BuiltIn",
    "mode": "Indexed",
    "description": "By default, regional VNET integration routes only RFC1918 traffic. Set 'vnetRouteAllEnabled' (API < 2024-11-01) or 'outboundVnetRouting.applicationTraffic' (API >= 2024-11-01) to route application traffic via the virtual network. Alternatively, set 'outboundVnetRouting.allTraffic' to route all traffic. Configuration traffic is handled separately by the configuration routing policy.",
    "metadata": {
      "version": "1.2.0",
      "category": "App Service"
    },
    "version": "1.2.0",
    "parameters": {
      "effect": {
        "type": "string",
        "defaultValue": "Audit",
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        }
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites"
          },
          {
            "field": "kind",
            "notContains": "functionapp"
          },
          {
            "anyOf": [
              {
                "allOf": [
                  {
                    "value": "[requestContext().apiVersion]",
                    "less": "2024-11-01"
                  },
                  {
                    "field": "Microsoft.Web/sites/vnetRouteAllEnabled",
                    "notEquals": "true"
                  }
                ]
              },
              {
                "allOf": [
                  {
                    "value": "[requestContext().apiVersion]",
                    "greaterOrEquals": "2024-11-01"
                  },
                  {
                    "field": "Microsoft.Web/sites/outboundVnetRouting.applicationTraffic",
                    "notEquals": "true"
                  },
                  {
                    "field": "Microsoft.Web/sites/outboundVnetRouting.allTraffic",
                    "notEquals": "true"
                  }
                ]
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.2.0",
      "1.1.0",
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/a691eacb-474d-47e4-b287-b4813ca44222",
  "name": "a691eacb-474d-47e4-b287-b4813ca44222"
}