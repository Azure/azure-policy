    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "in": [
              "Microsoft.Compute/virtualMachines",
              "Microsoft.Compute/virtualMachineScaleSets"
            ]
          },
          {
            "field": "tags['LegacyVMNVA']",
            "exists": false
          },
          {
            "allOf": [
              {
                "anyOf": [
                  {
                    "field": "Microsoft.Compute/virtualMachines/storageProfile.imageReference.publisher",
                    "in": "[parameters('allowedPublishers')]"
                  },
                  {
                    "field": "Microsoft.Compute/virtualMachineScaleSets/virtualMachineProfile.storageProfile.imageReference.publisher",
                    "in": "[parameters('allowedPublishers')]"
                  }
                ]
              },
              {
                "anyOf": [
                  {
                    "count": {
                      "value": "[parameters('allowedOffers')]",
                      "name": "offer",
                      "where": {
                        "field": "Microsoft.Compute/virtualMachines/storageProfile.imageReference.offer",
                        "like": "[current('offer')]"
                      }
                    },
                    "greater": 0
                  },
                  {
                    "count": {
                      "value": "[parameters('allowedOffers')]",
                      "name": "offer",
                      "where": {
                        "field": "Microsoft.Compute/virtualMachineScaleSets/virtualMachineProfile.storageProfile.imageReference.offer",
                        "like": "[current('offer')]"
                      }
                    },
                    "greater": 0
                  }
                ]
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "roleDefinitionIds": [
            "/providers/microsoft.authorization/roleDefinitions/b24988ac-6180-42a0-ab88-20f7382dd24c"
          ],
          "operations": [
            {
              "operation": "addOrReplace",
              "field": "tags['LegacyVMNVA']",
              "value": "[parameters('tagValue')]"
            }
          ]
        }
      }
    },
    "versions": [
