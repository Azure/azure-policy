{
  "properties": {
    "displayName": "Adds a tag to Network Virtual Appliances (NVAs) VMs and VMSS for MANA support",
    "policyType": "BuiltIn",
    "mode": "Indexed",
    "description": "Applies a tag for Marketplace NVA deployments when the NVA is using existing VM sizes. Please refer to https://aka.ms/manasupportforexistingvmfamilynva.",
    "metadata": {
      "version": "1.0.0",
      "category": "Compute"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "The effect determines what happens when the policy rule is evaluated to match."
        },
        "allowedValues": [
          "Modify",
          "Disabled"
        ],
        "defaultValue": "Modify"
      },
      "tagValue": {
        "type": "String",
        "metadata": {
          "displayName": "Tag Value",
          "description": "The value to be added to the tag 'LegacyVMNVA' when the policy rule is matched."
        },
        "defaultValue": ""
      },
      "allowedPublishers": {
        "type": "Array",
